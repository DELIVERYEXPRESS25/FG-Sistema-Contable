# ═══════════════════════════════════════════════════════════
# Flask
# ═══════════════════════════════════════════════════════════
FLASK_ENV=production
FLASK_DEBUG=0
SECRET_KEY=change-this-secret-key-in-production
HOST=0.0.0.0
PORT=5000

# ═══════════════════════════════════════════════════════════
# Base de Datos
# ═══════════════════════════════════════════════════════════
# Tipos: sqlite, postgresql, mysql
DB_TYPE=sqlite
DB_PATH=.colectivo_fg.db

# Para PostgreSQL/MySQL (descomenta y configura si usas)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=colectivo_fg
# DB_USER=admin
# DB_PASSWORD=secret